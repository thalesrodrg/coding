import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int num1;

        for (int i = 1; i <= 5; i++) {
            System.out.print("Digite um valor "+ i +":");
            num1 = sc.nextInt();

            System.out.println("Dobro: " + (num1 * 2));
        }

    }
}

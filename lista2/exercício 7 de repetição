import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        double nota;
        double maior = 0;
        double menor = 10;

        for (int i = 1; i <= 5; i++) {
            System.out.print("Digite a nota: ");
            nota = sc.nextDouble();

            if (nota > maior) {
                maior = nota;
            }

            if (nota < menor) {
                menor = nota;
            }
        }

        System.out.println("Maior nota: " + maior);
        System.out.println("Menor nota: " + menor);

    
    }
}
